# Google AI Studio API key (free at aistudio.google.com/apikey)
GOOGLE_API_KEY=your-google-ai-studio-key-here

# Required for ADK web UI and FastAPI - must be set to false to use AI Studio key
GOOGLE_GENAI_USE_VERTEXAI=false

# GCP project settings
GCP_PROJECT_ID=legal-adk
GCP_REGION=us-central1

# GCS corpus buckets
GCS_CORPUS_BUCKET_RAW=legal-adk-corpus-raw
GCS_CORPUS_BUCKET_PROCESSED=legal-adk-corpus-processed

# Vertex AI Search
VERTEX_SEARCH_LOCATION=us
VERTEX_SEARCH_DATASTORE_ID=legal-search-shared_1774804330209_gcs_store
SEARCH_ENGINE_ID=legal-search-app_1774806682231

# Gemini model
GEMINI_MODEL=gemini-2.5-flash

# CourtListener API token (free at courtlistener.com/profile/api-token/)
COURTLISTENER_TOKEN=your-courtlistener-token-here

# Local development flag
LOCAL_DEV=true
